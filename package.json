{
  "name": "ats-resume-analyzer",
  "version": "1.0.0",
  "description": "ATS Resume Analyzer - Optimize your resume for Applicant Tracking Systems",
  "type": "module",
  "main": "server/index.ts",
  "scripts": {
    "start": "tsx server/index.ts",
    "dev": "tsx watch server/index.ts",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "dev:all": "concurrently \"npm run dev\" \"npm run client\""
  },
  "keywords": [
    "ats",
    "resume",
    "analyzer",
    "job",
    "application"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "mammoth": "^1.12.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.6",
    "concurrently": "^8.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
