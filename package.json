{
  "name": "ats-resume-analyzer",
  "version": "1.0.0",
  "description": "ATS Resume Analyzer - Optimize your resume for Applicant Tracking Systems",
  "type": "module",
  "main": "server/index.ts",
  "scripts": {
    "start": "tsx server/index.ts",
    "dev": "tsx watch server/index.ts",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "build:prod": "cd client && npm run build && cd .. && tsx server/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run client\""
  },
  "keywords": [
    "ats",
    "resume",
    "analyzer",
    "job",
    "application"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "openai": "^6.38.0",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.0",
    "concurrently": "^9.2.1",
    "npm-check-updates": "^22.2.0",
    "tsx": "^4.22.2",
    "typescript": "^6.0.3"
  }
}
