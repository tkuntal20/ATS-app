{
  "name": "ats-resume-analyzer",
  "version": "1.0.0",
  "description": "CLI tool to analyze resumes against job descriptions and provide ATS score with suggestions",
  "main": "dist/cli.js",
  "bin": {
    "ats-app": "dist/cli.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc && node dist/cli.js",
    "start": "node dist/cli.js",
    "test": "node --test dist/test/*.test.js"
  },
  "keywords": [
    "ats",
    "resume",
    "job-description",
    "analyzer",
    "cli",
    "scoring"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "mammoth": "^1.6.0",
    "multer": "^2.1.1",
    "natural": "^6.7.0",
    "octokit": "^3.1.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.6",
    "@types/pdf-parse": "^1.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
